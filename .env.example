# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Optional. Render onrender.com deploys use RENDER_EXTERNAL_URL automatically.
# PUBLIC_BASE_URL=https://your-custom-domain.example
BOT_ADMIN_IDS=
DELETE_COOKIE_MESSAGES=true

# Supabase/Postgres
# Use the Supabase Session Pooler connection string on IPv4-only hosts.
DATABASE_URL=
AUTO_INIT_DB=true
# Stable secret. Keep the same value when reusing the same Supabase database.
ENCRYPTION_KEY=

# Render/server runtime
PORT=10000
HEADLESS=true
LOG_LEVEL=INFO
TELEGRAM_UPLOAD_DIR=artifacts/telegram_uploads
AIOHTTP_CLIENT_MAX_SIZE=33554432
AUTO_SET_TELEGRAM_WEBHOOK=true
TELEGRAM_DROP_PENDING_UPDATES=false
RESTART_BROADCAST_ENABLED=true

# Account isolation and cookie-use cooldown
BOT_ACCOUNT_COOKIE_COOLDOWN_SECONDS=360
BOT_ACCOUNT_LOCK_LEASE_SECONDS=1800
BOT_ACCOUNT_LOCK_MAX_WAIT_SECONDS=3600
BOT_ACCOUNT_LOCK_POLL_SECONDS=10
BOT_ACCOUNT_LOCK_HEARTBEAT_SECONDS=30
BOT_ALLOW_ACCOUNT_OWNERSHIP_TRANSFER=true
BOT_DASHBOARD_SESSION_TTL_SECONDS=1800
BOT_PROGRESS_EDIT_MIN_SECONDS=1.5
BOT_ACCOUNT_NAME_LOOKUP_TIMEOUT_SECONDS=45

# Playwright/Facebook engine runtime
FACEBOOK_BROWSER_ACCOUNT_LOOKUP_FALLBACK_ENABLED=true
POST_COOKIE_MIN_INTERVAL_SECONDS=360
POST_COOKIE_SESSION_LOCK_ENABLED=true
POST_COOKIE_SESSION_LOCK_WAIT_SECONDS=900
POST_COOKIE_SESSION_LOCK_TTL_SECONDS=1800
POST_ENABLE_PAGES_PORTAL_FALLBACK=true
POST_PAGES_PORTAL_FALLBACK_IMAGE_ENABLED=true
POST_PAGES_PORTAL_FALLBACK_VIDEO_ENABLED=true
POST_PARALLEL_BATCH_ENABLED=false
POST_ALLOW_PARALLEL_SAME_COOKIE=false
POST_PARALLEL_SAME_COOKIE_MAX_CONTEXTS=1
MAX_PARALLEL_PAGES=1
POST_PARALLEL_SAME_COOKIE_STAGGER_SECONDS=0
POST_PARALLEL_ENABLE_PAGES_PORTAL_FALLBACK=true
POST_PARALLEL_PAGES_PORTAL_TEXT_TIMEOUT_SECONDS=60
POST_PARALLEL_PAGES_PORTAL_IMAGE_TIMEOUT_SECONDS=90
POST_PARALLEL_PAGES_PORTAL_VIDEO_TIMEOUT_SECONDS=120
FACEBOOK_MEDIA_UPLOAD_MAX_ZERO_NETWORK_ATTEMPTS=2
POST_PAGES_PORTAL_FIRST=true
POST_PAGES_PORTAL_FIRST_IMAGE_ENABLED=true
POST_PAGES_PORTAL_FIRST_VIDEO_ENABLED=true
FACEBOOK_IMAGE_FORCE_SANITIZE_UPLOAD=true
FACEBOOK_IMAGE_PREFER_JPEG_UPLOAD=true

# Optional local browser override
# FACEBOOK_BROWSER_EXECUTABLE=/path/to/google-chrome
