# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Optional. Render onrender.com deploys use RENDER_EXTERNAL_URL automatically.
# PUBLIC_BASE_URL=https://your-custom-domain.example
BOT_ADMIN_IDS=
BOT_REQUIRE_USER_APPROVAL=true
DELETE_COOKIE_MESSAGES=true

# Supabase/Postgres
# Use the Supabase Session Pooler connection string on IPv4-only hosts.
DATABASE_URL=
AUTO_INIT_DB=true
# Stable secret. Keep the same value when reusing the same Supabase database.
ENCRYPTION_KEY=

# Render/server runtime
PORT=10000
HEADLESS=true
LOG_LEVEL=INFO
TELEGRAM_UPLOAD_DIR=artifacts/telegram_uploads
AIOHTTP_CLIENT_MAX_SIZE=33554432
AUTO_SET_TELEGRAM_WEBHOOK=true
TELEGRAM_DROP_PENDING_UPDATES=false
RESTART_BROADCAST_ENABLED=true

# Account isolation and cookie-use cooldown
BOT_ACCOUNT_COOKIE_COOLDOWN_SECONDS=360
BOT_ACCOUNT_LOCK_LEASE_SECONDS=1800
BOT_ACCOUNT_LOCK_MAX_WAIT_SECONDS=3600
BOT_ACCOUNT_LOCK_POLL_SECONDS=10
BOT_ACCOUNT_LOCK_HEARTBEAT_SECONDS=30
BOT_ALLOW_ACCOUNT_OWNERSHIP_TRANSFER=true
BOT_DASHBOARD_SESSION_TTL_SECONDS=1800
BOT_PROGRESS_EDIT_MIN_SECONDS=1.5
BOT_ACCOUNT_NAME_LOOKUP_TIMEOUT_SECONDS=45
BOT_PAGE_DISCOVERY_TIMEOUT_SECONDS=150
BOT_ACCOUNT_ADD_PAGE_DISCOVERY_TIMEOUT_SECONDS=150
BOT_BATCH_POSTING_ENGINE_TIMEOUT_SECONDS=3600

# Playwright/Facebook engine runtime
FACEBOOK_BROWSER_ACCOUNT_LOOKUP_FALLBACK_ENABLED=true
POST_COOKIE_MIN_INTERVAL_SECONDS=900
POST_COOKIE_SECURITY_COOLDOWN_SECONDS=86400
POST_COOKIE_SESSION_LOCK_ENABLED=true
POST_COOKIE_SESSION_LOCK_WAIT_SECONDS=900
POST_COOKIE_SESSION_LOCK_TTL_SECONDS=1800
POST_BATCH_PAGE_TIMEOUT_SECONDS=180
POST_BATCH_PAGE_TIMEOUT_MAX_SECONDS=300
POST_DIRECT_COMPOSER_TIMEOUT_SECONDS=45
POST_BATCH_HOME_WAIT_UNTIL=commit
POST_BATCH_HOME_READY_TIMEOUT_MS=2000
POST_BATCH_HOME_NETWORK_IDLE_TIMEOUT_MS=0
POST_PAGES_PORTAL_TEXT_TIMEOUT_SECONDS=120
POST_PAGES_PORTAL_IMAGE_TIMEOUT_SECONDS=180
POST_PAGES_PORTAL_VIDEO_TIMEOUT_SECONDS=240
POST_PUBLISH_IN_PROGRESS_TIMEOUT_MS=15000
POST_ACCEPT_POST_PUBLISH_POPUP_AS_SUCCESS=true
POST_PROFILE_SWITCH_SETTLE_GRACE_SECONDS=3
POST_PROFILE_SWITCH_FAST_SETTLE_TIMEOUT_MS=2500
POST_PROFILE_SWITCH_FAST_SETTLE_GRACE_SECONDS=1
POST_PROFILE_SWITCH_CONFIRM_TIMEOUT_MS=1200
POST_INITIAL_UI_CONFIRMATION_TIMEOUT_MS=3500
POST_VIDEO_NETWORK_CONFIRMATION_TIMEOUT_MS=3500
POST_COMPOSER_BUTTON_TIMEOUT_MS=5000
POST_COMPOSER_DIALOG_TIMEOUT_MS=6500
MEDIA_UPLOAD_READY_IMAGE_TIMEOUT=30
MEDIA_UPLOAD_READY_VIDEO_TIMEOUT=120
FB_AUTOMATION_ENABLE_PRIVATE_HTTP=false
POST_ENABLE_PAGES_PORTAL_FALLBACK=false
POST_PAGES_PORTAL_FALLBACK_IMAGE_ENABLED=false
POST_PAGES_PORTAL_FALLBACK_VIDEO_ENABLED=false
POST_PARALLEL_BATCH_ENABLED=true
POST_ALLOW_PARALLEL_SAME_COOKIE=true
POST_PARALLEL_SAME_COOKIE_MAX_CONTEXTS=3
MAX_PARALLEL_PAGES=3
POST_PARALLEL_SAME_COOKIE_STAGGER_SECONDS=1.5
POST_PARALLEL_ENABLE_PAGES_PORTAL_FALLBACK=false
POST_PARALLEL_PAGES_PORTAL_TEXT_TIMEOUT_SECONDS=60
POST_PARALLEL_PAGES_PORTAL_IMAGE_TIMEOUT_SECONDS=90
POST_PARALLEL_PAGES_PORTAL_VIDEO_TIMEOUT_SECONDS=120
FACEBOOK_MEDIA_UPLOAD_MAX_ZERO_NETWORK_ATTEMPTS=2
POST_PAGES_PORTAL_FIRST=false
POST_PAGES_PORTAL_FIRST_IMAGE_ENABLED=false
POST_PAGES_PORTAL_FIRST_VIDEO_ENABLED=false
FACEBOOK_IMAGE_FORCE_SANITIZE_UPLOAD=true
FACEBOOK_IMAGE_PREFER_JPEG_UPLOAD=true

# Optional local browser override
# FACEBOOK_BROWSER_EXECUTABLE=/path/to/google-chrome
